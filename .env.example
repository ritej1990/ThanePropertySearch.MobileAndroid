# Copy to ".env" in this folder. Restart `expo start` after edits.
#
# Production API (Azure):
EXPO_PUBLIC_API_BASE_URL=https://tpsapi.azurewebsites.net
# Public website — Cashfree return URLs (must match API Web:BaseUrl host):
# EXPO_PUBLIC_WEB_BASE_URL=https://www.thaneflats.com
# Property photos: API returns localhost URLs — app rewrites to this host (optional override):
# EXPO_PUBLIC_MEDIA_BASE_URL=https://tpsapi.azurewebsites.net
#
# Google Maps — Places Autocomplete + property map pins (enable Places API + Maps SDK for Android/iOS):
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
#
# Local dev (Expo Go on a phone cannot use localhost — use your PC LAN IP):
# EXPO_PUBLIC_API_BASE_URL=https://192.168.1.10:44396
